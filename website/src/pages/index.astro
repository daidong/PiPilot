              <div><span class="text-mint-300">ANTHROPIC_API_KEY</span>  <span class="text-slate-500"># Claude models</span></div>
              <div><span class="text-mint-300">OPENAI_API_KEY</span>     <span class="text-slate-500"># GPT / o-series models</span></div>
              <div><span class="text-mint-300">BRAVE_API_KEY</span>      <span class="text-slate-500"># web search (recommended)</span></div>
              <div><span class="text-mint-300">OPENROUTER_API_KEY</span> <span class="text-slate-500"># AI diagrams (optional)</span></div>
