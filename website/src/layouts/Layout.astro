---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AI-powered desktop research assistant for scientists and academics.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Theme boot: applies stored / system preference before first paint
         so the page never flashes the wrong palette. Mirrors the toggle
         logic at the bottom of index.astro. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('rc-theme');
          var prefersLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
          var theme = stored || (prefersLight ? 'light' : 'dark');
          if (theme === 'light') document.documentElement.classList.add('light');
        } catch (_e) {
          /* localStorage may be blocked in privacy modes — fall back to dark default */
        }
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${base}default-screen.png`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-950 text-slate-200 font-sans antialiased">
    <slot />
  </body>
</html>
