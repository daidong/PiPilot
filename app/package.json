{
  "name": "@research-copilot/app",
  "version": "0.4.8",
  "private": true,
  "description": "AI-powered research assistant desktop application",
  "homepage": "https://github.com/DIR-LAB/Research-Pilot",
  "main": "./out/main/index.mjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icon:generate": "python3 scripts/generate-app-icon.py",
    "pack": "electron-vite build && electron-builder --mac",
    "pack:mac": "electron-vite build && electron-builder --mac",
    "pack:win": "electron-vite build && electron-builder --win",
    "pack:linux": "electron-vite build && electron-builder --linux",
    "pack:all": "electron-vite build && electron-builder -mwl"
  },
  "author": {
    "name": "Dong Dai",
    "email": "daidongly@gmail.com"
  },
  "build": {
    "appId": "com.research-copilot.app",
    "productName": "Research Copilot",
    "electronVersion": "33.4.11",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "executableName": "research-copilot",
      "category": "Science",
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "synopsis": "AI-powered research assistant",
      "description": "Literature search, data analysis, academic writing, and cross-project paper memory."
    },
    "publish": [
      {
        "provider": "github",
        "owner": "DIR-LAB",
        "repo": "Research-Pilot",
        "releaseType": "draft"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../lib/skills/builtin",
        "to": "skills/builtin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../lib/skills/data-analysis",
        "to": "skills/data-analysis",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.717.0",
    "@aws-sdk/client-s3": "^3.717.0",
    "@aws-sdk/client-sts": "^3.717.0",
    "@aws-sdk/s3-request-presigner": "^3.717.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@mariozechner/pi-agent-core": "^0.70.2",
    "@mariozechner/pi-ai": "^0.70.2",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "@milkdown/plugin-diagram": "^7.7.0",
    "@milkdown/react": "^7.18.0",
    "@sinclair/typebox": "^0.34.48",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "codemirror": "^6.0.2",
    "electron-updater": "^6.8.3",
    "katex": "^0.16.28",
    "lucide-react": "^0.469.0",
    "mermaid": "^11.12.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.0",
    "ssh2": "^1.16.0",
    "zustand": "^5.0.3"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.5",
    "electron": "^33.3.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
