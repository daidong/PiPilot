{
  "name": "research-copilot",
  "version": "0.2.22",
  "description": "AI-powered research assistant for scientists — literature search, data analysis, academic writing, and project management",
  "type": "module",
  "bin": {
    "research-copilot": "./bin/cli.mjs",
    "research-copilot-diagnostics": "./bin/diagnostics.mjs"
  },
  "files": [
    "bin/",
    "app/out/",
    "app/build/",
    "app/package.json",
    "lib/skills/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "app",
    "lib",
    "shared-ui",
    "shared-electron"
  ],
  "scripts": {
    "dev": "cd app && npx electron-vite dev",
    "build": "cd app && npx electron-vite build",
    "clean": "rm -rf app/out app/dist",
    "postinstall": "node ./scripts/fix-node-pty-perms.mjs",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx --test lib/telemetry/__tests__/*.test.ts lib/telemetry/diagnostics/__tests__/*.test.ts lib/ledger/__tests__/*.test.ts app/src/renderer/stores/__tests__/*.test.ts",
    "test:telemetry": "node --import tsx --test lib/telemetry/__tests__/*.test.ts",
    "test:ledger": "node --import tsx --test lib/ledger/__tests__/*.test.ts",
    "test:renderer": "node --import tsx --test app/src/renderer/stores/__tests__/*.test.ts",
    "test:diagnostics": "node --import tsx --test lib/telemetry/diagnostics/__tests__/*.test.ts",
    "diagnostics": "node bin/diagnostics.mjs"
  },
  "keywords": [
    "research",
    "ai",
    "academic",
    "literature-search",
    "data-analysis",
    "electron",
    "desktop"
  ],
  "author": "daidong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daidong/PiPilot.git"
  },
  "homepage": "https://daidong.github.io/PiPilot/",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.70.2",
    "@mariozechner/pi-ai": "^0.70.2",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^1.30.1",
    "@opentelemetry/core": "^1.30.1",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sinclair/typebox": "^0.34.48",
    "adm-zip": "^0.5.16",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "electron": "^33.3.1",
    "ignore": "^7.0.5",
    "minimatch": "^10.2.4",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
