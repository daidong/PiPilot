{
  "name": "agent-foundry",
  "version": "0.1.0",
  "description": "Agent Framework v2 - Three-axis orthogonal architecture: Tools + Policies + Context Sources",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-foundry": "./dist/cli/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./team": {
      "import": "./dist/team/index.js",
      "types": "./dist/team/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run copy-data",
    "copy-data": "mkdir -p dist/recommendation/data && cp src/recommendation/data/*.yaml dist/recommendation/data/",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "validate-catalog": "npx tsx scripts/validate-catalog.ts",
    "validate-catalog:offline": "npx tsx scripts/validate-catalog.ts --skip-network",
    "validate-catalog:fix": "npx tsx scripts/validate-catalog.ts --fix-dates"
  },
  "keywords": [
    "agent",
    "ai",
    "llm",
    "framework",
    "tools",
    "policies",
    "context"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.24",
    "ai": "^4.3.19",
    "glob": "^10.3.0",
    "tiktoken": "^1.0.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
